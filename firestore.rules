rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getDeal(dealId) {
      return get(/databases/$(database)/documents/deals/$(dealId)).data;
    }

    match /deals/{dealId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.token.email == resource.data.partyAEmail ||
        request.auth.token.email == resource.data.partyBEmail
      );
      allow write: if false;

      match /bids/{bidId} {
        allow read: if isAuthenticated() && (
          exists(/databases/$(database)/documents/deals/$(dealId)) &&
          (request.auth.token.email == getDeal(dealId).partyAEmail || request.auth.token.email == getDeal(dealId).partyBEmail) &&
          (resource == null || (
            (resource.data.party == 'A' && request.auth.token.email == getDeal(dealId).partyAEmail) ||
            (resource.data.party == 'B' && request.auth.token.email == getDeal(dealId).partyBEmail)
          ))
        );
        allow write: if false;
      }
    }
  }
}
