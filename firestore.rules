rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /deals/{dealId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.partyAEmail ||
        request.auth.token.email == resource.data.partyBEmail
      );
      allow write: if false;

      match /bids/{bidId} {
        allow read: if isAuthenticated() && (
          (resource.data.party == 'A' && request.auth.token.email == get(/databases/$(database)/documents/deals/$(dealId)).data.partyAEmail) ||
          (resource.data.party == 'B' && request.auth.token.email == get(/databases/$(database)/documents/deals/$(dealId)).data.partyBEmail)
        );
        allow write: if false;
      }
    }
  }
}
